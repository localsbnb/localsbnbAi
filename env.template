# 路客云API配置
LUKEYUN_API_BASE_URL=https://api.lukeyun.com

# Hudson认证配置（用于新接口）
# 请替换为您的实际值
HUDSON_ACCESS_TOKEN=your-hudson-access-token-here
CAMP_ID=your-camp-id-here

# 服务配置
NODE_ENV=development
LOG_LEVEL=info

# 日志配置
LOG_FORMAT=json
# 是否写入项目目录下 logs/combined.log、logs/error.log（默认不写，仅 stderr，避免 npx 全局运行时污染目录）
# LOCALSBNB_LOG_TO_FILES=1

# 缓存配置（可选）
CACHE_ENABLED=true
CACHE_TTL=300000

# 重试配置（可选）
MAX_RETRIES=3
RETRY_DELAY=1000
