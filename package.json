{
  "name": "localsbnb-mcp-server",
  "version": "1.0.10",
  "description": "LocalsBnb MCP Server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean-dist.cjs",
    "build": "tsc && cp dist/index.js dist/start.mjs && cp scripts/run-mcp.cjs dist/run.cjs && cp scripts/run-mcp.sh dist/run.sh && cp package.json dist/package.json && chmod +x dist/run.sh dist/start.sh 2>/dev/null || true",
    "build:prod": "tsc -p tsconfig.prod.json && cp dist/index.js dist/start.mjs && cp scripts/run-mcp.cjs dist/run.cjs && cp scripts/run-mcp.sh dist/run.sh && cp package.json dist/package.json && node scripts/obfuscate-dist.cjs && chmod +x dist/run.sh 2>/dev/null || true",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run clean && npm run build:prod",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:api": "node scripts/dev/test-api.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "localsbnb",
    "mcp",
    "model-context-protocol",
    "lukeyun",
    "pms",
    "hotel-management",
    "cursor",
    "claude"
  ],
  "author": "Lukeyun",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "bin": {
    "localsbnb-mcp": "dist/run.cjs",
    "lukeyun-pms-mcp": "dist/run.cjs"
  },
  "devDependencies": {
    "javascript-obfuscator": "^4.1.1",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "mcp.sample.json"
  ]
}
